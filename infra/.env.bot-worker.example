# Worker Bot Trading (Polymarket) — variables d'environnement OVH VPS
# Copier vers .env.bot-worker et compléter avant `docker compose up`.

NODE_ENV=production

# Même base que l'API principale (Railway/Neon/etc.) — le worker lit/écrit
# les mêmes tables TradingBot / BotDecision / BotEvent.
DATABASE_URL=postgresql://user:password@host:5432/merkure_db

# Même Redis que l'API principale (files BullMQ partagées).
REDIS_URL=redis://user:password@host:6379

# Clé de chiffrement des credentials wallet — DOIT être identique à celle
# de l'API principale (sinon impossible de déchiffrer les clés privées
# déjà stockées).
ENCRYPTION_KEY=

# Agent Claude
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB — laisser vide pour rester en mode simulé
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# Dune Analytics (détection wallets baleines) — laisser vide pour rester en mode simulé
DUNE_API_KEY=
DUNE_WHALE_QUERY_ID=

# Fréquence des cycles de l'agent, en ms (défaut 120000 = 2 min)
BOT_TRADING_TICK_MS=120000

# Sentry (optionnel)
SENTRY_DSN=

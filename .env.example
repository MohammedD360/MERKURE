# ─────────────────────────────────────────────
# MERKURE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS commiter le .env
# ─────────────────────────────────────────────

# ─── App ────────────────────────────────────
NODE_ENV=development

# ─── PostgreSQL ─────────────────────────────
POSTGRES_USER=merkure
POSTGRES_PASSWORD=merkure_dev_password
POSTGRES_DB=merkure_db
DATABASE_URL=postgresql://merkure:merkure_dev_password@localhost:5432/merkure_db

# ─── Redis ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth local-first / Clerk ───────────────
AUTH_MODE=demo
# AUTH_MODE=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxx

# ─── Auth JWT legacy API ────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_generate_64_bytes_hex_string_here_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_generate_64_bytes_hex_string_here_yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── AI Service ─────────────────────────────
AI_SERVICE_URL=http://localhost:8000
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_SERVICE_SECRET=change_me_generate_32_bytes_hex

# ─── Anthropic (Claude API) ─────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ─── MetaAPI (MT4/MT5) ──────────────────────
META_API_TOKEN=

# ─── Email (Resend) ─────────────────────────
# OBLIGATOIRE en production (reset mdp, bienvenue, paiement)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=noreply@merkure.app

# ─── Stripe ─────────────────────────────────
# OBLIGATOIRE en production
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx
STRIPE_PRICE_ELITE=price_xxxxxxxx

# ─── Sentry (monitoring erreurs) ────────────
# Optionnel en dev, recommandé en production
# Récupérer sur https://sentry.io → Paramètres → DSN
SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Pour le web Next.js (exposé côté client)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Pour l'upload des source maps (CI/CD seulement)
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxx
# SENTRY_ORG=merkure
# SENTRY_PROJECT=merkure-web

# ─── Encryption (credentials broker) ────────
# OBLIGATOIRE — Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change_me_64_hex_chars_representing_32_bytes_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

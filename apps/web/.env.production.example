# ─────────────────────────────────────────────────────────────────────────────
# MERKURE Web — Variables d'environnement PRODUCTION (Next.js)
# Les variables NEXT_PUBLIC_* sont exposées côté client (navigateur)
# Les autres variables restent côté serveur uniquement
# NE JAMAIS commiter un fichier .env contenant des valeurs réelles
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Backend ──────────────────────────────────────────────────────────────
# URL publique du service API Railway (exposée dans le navigateur)
# Ex : https://merkure-api.up.railway.app
NEXT_PUBLIC_API_URL=https://merkure-api.up.railway.app

# ─── WebSocket ────────────────────────────────────────────────────────────────
# URL WebSocket de l'API (même hôte, protocole wss://)
# Ex : wss://merkure-api.up.railway.app
NEXT_PUBLIC_WS_URL=wss://merkure-api.up.railway.app

# ─── Clerk (authentification) ─────────────────────────────────────────────────
# Utiliser les clés de PRODUCTION (pk_live_ / sk_live_)
# Disponible sur https://dashboard.clerk.com → API Keys
# Seule NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY est exposée côté client
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

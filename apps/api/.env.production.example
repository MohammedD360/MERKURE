# ─────────────────────────────────────────────────────────────────────────────
# MERKURE API — Variables d'environnement PRODUCTION
# Copier ce fichier, remplir toutes les valeurs, et les injecter dans Railway
# NE JAMAIS commiter un fichier .env contenant des valeurs réelles
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── PostgreSQL (Neon.tech) ───────────────────────────────────────────────────
# Disponible dans le dashboard Neon : Settings → Connection string
# Format : postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://merkure_prod:STRONG_PASSWORD@ep-xxxx-xxxx.eu-west-1.aws.neon.tech/merkure_prod?sslmode=require

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Disponible dans le dashboard Upstash : Data → REST API → Redis URL
# Format : rediss://default:TOKEN@endpoint.upstash.io:6380
REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@your-endpoint.upstash.io:6380

# ─── Authentification ────────────────────────────────────────────────────────
# Choisir entre "demo" (pas de Clerk nécessaire) ou "clerk" (Clerk requis)
# Pour la bêta avec 50 testeurs : AUTH_MODE=clerk recommandé
AUTH_MODE=clerk

# Clerk — disponible sur https://dashboard.clerk.com → API Keys
# Utiliser les clés de PRODUCTION (pas les clés test pk_test_/sk_test_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret du webhook Clerk (Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── JWT (utilisé si AUTH_MODE=demo) ─────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_64_BYTES_HEX_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_BYTES_HEX_STRING_HERE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL publique du service web Railway (ex: https://merkure-web.up.railway.app)
FRONTEND_URL=https://merkure-web.up.railway.app

# ─── Service IA Python ────────────────────────────────────────────────────────
# URL interne Railway du service ai-service (réseau privé)
# En production Railway : utiliser l'URL privée (ex: http://ai-service.railway.internal:8000)
AI_SERVICE_URL=http://ai-service.railway.internal:8000
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AI_SERVICE_SECRET=GENERATE_32_BYTES_HEX_STRING_HERE

# ─── Anthropic (Claude API) ───────────────────────────────────────────────────
# Disponible sur https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MetaAPI (MT4/MT5) ───────────────────────────────────────────────────────
# Disponible sur https://app.metaapi.cloud → API Access → Token
# Laisser vide si la fonctionnalité MT4/MT5 n'est pas activée en bêta
META_API_TOKEN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Utiliser les clés LIVE pour la production (pas sk_test_)
# Disponible sur https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Secret du webhook (Stripe Dashboard → Webhooks → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Price IDs des plans (Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ELITE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Chiffrement des credentials broker ──────────────────────────────────────
# Clé AES-256 : exactement 64 caractères hexadécimaux (= 32 bytes)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ATTENTION : si cette clé change, tous les credentials broker chiffrés deviennent illisibles
ENCRYPTION_KEY=GENERATE_64_HEX_CHARS_HERE_EXACTLY_64_CHARACTERS_ABCDEF0123456789AB
